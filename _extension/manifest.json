{
  "manifest_version": 3,
  "name": "Piyyg Proctor Scraper",
  "version": "1.0.0",
  "description": "Proctor-session-based batch scraping orchestration for MSR-Insight.",
  "permissions": [
    "storage",
    "cookies"
  ],
  "host_permissions": [
    "http://127.0.0.1:5001/*",
    "http://localhost:5001/*",
    "http://127.0.0.1:3000/*",
    "http://localhost:3000/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Piyyg Scraper"
  },
  "content_scripts": [
    {
      "matches": [
        "http://localhost:3000/*",
        "http://127.0.0.1:3000/*"
      ],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ]
}
